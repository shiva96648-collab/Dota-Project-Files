var GoogleMapView = Backbone.View.extend({
						el:$('#map-control'),
						initialize:function() { 
							this.map = null;
							this.drawingManager = null;
							this.listenTo(this.model, 'change', this.render);
							this.render();
							},
						render: function() {
							console.log('map view render');
							if (this.map != null) { this.setUpMap(); }
							},
						setUpMap: function() { 
							if (this.map == null) {
									this.map = new google.maps.Map(this.el);
									this.map.setCenter(this.model.get("centre"));
									this.map.setZoom(this.model.get("zoom"));
							
									this.drawingManager = new google.maps.drawing.DrawingManager({
											drawingMode: google.maps.drawing.OverlayType.MARKER,
											drawingControl: true,
											drawingControlOptions: {
											  position: google.maps.ControlPosition.TOP_CENTER,
											  drawingModes: [
												google.maps.drawing.OverlayType.MARKER,
												google.maps.drawing.OverlayType.POLYGON,
												google.maps.drawing.OverlayType.POLYLINE,
												google.maps.drawing.OverlayType.RECTANGLE
											  ]
											},
											markerOptions: {draggable:true, raiseOnDrag:true}
										  });
									this.drawingManager.setMap(this.map);
									google.maps.event.addListener(this.drawingManager, 'overlaycomplete', this.processDrawingObject.bind(this));
								}
							
							},
						processDrawingObject: function(e) {
						
							if (debug) { console.log('process map drawing object: ' + e.type); }
							
							var shape = new Shape();
							var points = shape.get("points");
							shape.set("mapShape", e.overlay);
							
							if (e.type == google.maps.drawing.OverlayType.MARKER) { 
									var marker = e.overlay; 
									marker.draggable = false; //No support for updating point data after dragging yet, so disabling dragging to avoid confusion.
									shape.name = "POINT";		
									points.add([{x:marker.getPosition().lng(), y:marker.getPosition().lat()}]); 
								}
							else if (e.type == google.maps.drawing.OverlayType.POLYGON) { 
									var polygon = e.overlay;
									shape.name = "POLYGON";
									polygon.getPath().forEach(function(latlng,idx) { points.add([{x:latlng.lng(), y:latlng.lat()}]); }); 
								}
							else if (e.type == google.maps.drawing.OverlayType.POLYLINE) { 
									var polyline = e.overlay; 
									shape.name = "PATH";
									polyline.getPath().forEach(function(latlng,idx) { points.add([{x:latlng.lng(), y:latlng.lat()}]); }); 
								}
							else if (e.type == google.maps.drawing.OverlayType.RECTANGLE) {
									var rectangle = e.overlay; 
									var bds = rectangle.getBounds();
									var ne = bds.getNorthEast();
									var sw = bds.getSouthWest();
									shape.name = "RECTANGLE";
									points.add([{y:ne.lat(), x:ne.lng()},
												{y:ne.lat(), x:sw.lng()},
												{y:sw.lat(), x:sw.lng()},
												{y:sw.lat(), x:ne.lng()},
												{y:ne.lat(), x:ne.lng()}]);
								}

							this.model.get("shapes").add(shape);

							},
						clearMap: function() {
							if (debug) { console.log('clearing map objects'); }
							console.log(this);
							//Complete current shape
							this.drawingManager.setDrawingMode(this.drawingManager.getDrawingMode());
							// remove from the map control
							this.model.get("shapes").each(function(shp) { 
											shp.get("mapShape").setMap(null); 
											shp.get("points").reset();
										});
							this.model.get("shapes").reset();
							},
						undoMap: function () {
							if (debug) { console.log('clearing latest map object'); }
							//Complete current shape
							this.drawingManager.setDrawingMode(this.drawingManager.getDrawingMode());
							//Pop last shape
							var lastShape = this.model.get("shapes").pop();
							// remove from the map control
							if (lastShape) {
								lastShape.get("mapShape").setMap(null);
								lastShape.get("points").reset();
							}
						},
						setLocation:function(location) {
							this.map.panTo(location);
							},
						setViewport:function(viewport) {
							this.map.fitBounds(viewport);
						}
							

})

var GoogleMapLocationView = Backbone.View.extend({
