// outputs

var OutputView = Backbone.View.extend({ 
						el:$("#sidebar-output"),
						initialize:function() { 
							if (debug) { console.log('initialized outputview'); }
							this.listenTo(this.model, 'change', this.render);
							this.listenTo(this.model, 'change:shapes', this.modelChanged);
							this.modelChanged();
							},
						events: {
							"change input[type=radio]" : "changeOutputFormat",
							"change textarea" : "userChangeCSV",
							"keyup textarea" : "userEditCSV",
							"select textarea" : "userSelectCSV"
							},
						render:function() {
								if (debug) { console.log('rendering output view'); }
								if (this.model.get("format") == "table") {
									this.$("#output-type-table").attr("checked",true);
									this.$("#output-table").html(this.createOutput());
									this.$("#output-table").show();
									this.$("#output-text").hide();
								} else { 
									this.$("#output-type-csv").attr("checked",true);
									this.$("#output-text").text(this.createOutput());
									this.$("#output-table").hide();
									this.$("#output-text").show();
								}
							},
						changeOutputFormat:function() {
							if (debug) { console.log('changed output type'); }
							this.model.set("format", this.$("input[name=output-type]:checked").val());
							},
						createOutput:function() {
						
							var fmt = this.model.get("format");
							var mde = this.model.get("mode");
							var useCustomScale = (this.model.get("scale").isCustomScale()) && (mde == "image");
							var outputArray = new Array();
							var header = new Array();
							var output = "";
																					
							// create a header array
							header.push("shape id");
							header.push("point id");
							if (mde == "image") {
								header.push("x");
								header.push("y");
								if (useCustomScale) {
									header.push("x2");
									header.push("y2");
								}
							} else {
								header.push("longitude");
								header.push("latitude");
							}
							outputArray.push(header);

							// now create row arrays
							var shapes = this.model.get("shapes");
							for (var s=0;s<shapes.length;s++) {
								var points = shapes.at(s).get("points");
								for (var p=0;p<points.length;p++) {
									var row = new Array();
									row.push(s);
									row.push(p);
									row.push(points.at(p).get("x"));
									if (mde == "image") {
										row.push(this.model.get("scale").get("height")-points.at(p).get("y"));
									} else {
										row.push(points.at(p).get("y"));
									}
									if (useCustomScale) {
										var scale = this.model.get("scale");
										var x2 = parseInt(scale.get("left")) + 
													(points.at(p).get("x") / scale.get("width"))
													* (scale.get("right") - scale.get("left"));
										var y2 = parseInt(scale.get("top")) + 
													(points.at(p).get("y") / scale.get("height"))
													* (scale.get("bottom") - scale.get("top"));
										row.push(x2.toFixed(4));
										row.push(y2.toFixed(4));
									}
									outputArray.push(row);
								}
							}
							
							// output the text and return
							for (var o=0; o<outputArray.length; o++) {
								if (fmt == "csv") { output += outputArray[o].join(",") + '\r\n'; }
								if (fmt == "table") { output += '<tr><td>' + outputArray[o].join("</td><td>") + '</td></tr>'; }
							}
							if (fmt == "table") { output = "<table>" + output + "</table>"; }
								
							return output;
						}, 
						modelChanged:function() {
							if (debug) { console.log('model changed : resubscribing to shape change models'); }
							this.listenTo(this.model.get("shapes"), 'change', this.render);
							this.listenTo(this.model.get("shapes"), 'add', this.render);
							this.listenTo(this.model.get("shapes"), 'remove', this.render);
							this.listenTo(this.model.get("shapes"), 'reset', this.render);
							this.render();
							},
						userChangeCSV:function() {
							if (debug) { console.log('the CSV Value has changed'); }
							},
						userEditCSV:function() {
							if (debug) { console.log('the CSV Value is being edited'); }
							},
						userSelectCSV:function() {
							if (debug) { console.log('a part of the CSV Value has been selected'); }
							
							// find the selection and work out which points have been selected
							// the action here is to hopefully highlight the points being edited
							// so that they can be deleted. we need a way to parse the input
							// and redraw the shapes
							
							var sel = this.$("#output-text").getSelection();
							var allText = this.$("#output-text").val();
							var allLines = allText.split(/\r\n|\n/g);
							var lmtch1 = allText.substring(0,sel.start).match(/\n/gi);
							var lmtch2 = allText.substring(0,sel.end).match(/\n/gi);
							var lnum1 = (lmtch1) ? lmtch1.length : 0;
							var lnum2 = (lmtch2) ? lmtch2.length : 0;
							var selectedLines = allLines.slice(lnum1,lnum2+1);
							
							
							
							}
});

var ClipboardView = Backbone.View.extend({
						el:$('#copy-clipboard-button'),
						initialize:function() {
							if (debug) { console.log('initializing clipboard'); }
							if (debug) { console.log('moviePath: ' + this.model.get("moviePath")); }
                            var id = '#' + this.el.id;
							this.clip = new Clipboard(id, {
                                text: function(trigger){
                                    if (this.model.get("format") == "table") {
                                        return $("#output-table").html();
                                    } else {
                                        return $("#output-text").val();
                                    }
                                }.bind(this)
                            });
							this.clip.on('success', this.copyContent.bind(this));
							this.showButton.bind(this)();
							},
						render:function() {
							},
						showButton:function(client,args) {
							if (debug) { console.log('clipboard has loaded'); }

                            if(Clipboard.isSupported()){
                                if (debug) { console.log('Clipboard supported in current browser, enabling copy button.'); }
                                this.$el.show();
                            }
                            else {
                                if (debug) { console.log('Clipboard not supported in current browser.'); }
                            }
							},
						copyContent:function(client,args){
							if (debug) { console.log('Copying to Clipboard'); }
							this.$el.text("Copied!");
							window.setTimeout(this.resetButton.bind(this), 1000);
							},
						resetButton:function() {
							this.$el.text("Copy");
							}
});

	
